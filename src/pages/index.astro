---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Prompt Hebdo — L'IA pratique, chaque semaine">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-badge">⚡ Newsletter gratuite &bull; 2x par semaine</div>
      <h1>Des <span class="highlight">prompts IA</span> prêts à l'emploi,<br/>chaque semaine dans ta boîte mail</h1>
      <p class="hero-sub">
        Outils testés, tutoriels express et prompts professionnels pour gagner du temps
        et automatiser ton quotidien avec l'intelligence artificielle.
      </p>
      <div class="hero-cta" id="inscription">
        <div class="signup-box">
          <p class="signup-label">Rejoins les lecteurs de Prompt Hebdo :</p>
          <form class="signup-placeholder" action="https://magic.beehiiv.com/v1/7b5351f8-902f-413c-b08b-9b85530a096e" method="get">
            <input type="email" name="email" placeholder="ton@email.com" class="signup-input" required />
            <button type="submit" class="btn-primary">S'inscrire gratuitement</button>
          </form>
          <p class="signup-hint">Gratuit. Pas de spam. Désinscription en 1 clic.</p>
        </div>
      </div>
      <div class="hero-proof">
        <span>🎯 100% pratique</span>
        <span>📬 2 éditions / semaine</span>
        <span>🆓 Toujours gratuit</span>
      </div>
    </div>
  </section>

  <!-- CE QUE TU RECOIS -->
  <section class="features">
    <div class="features-inner">
      <h2>Ce que tu reçois chaque semaine</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🛠️</div>
          <h3>L'outil IA de la semaine</h3>
          <p>Un outil testé en conditions réelles avec verdict honnête : ce qu'il fait bien, ce qu'il fait mal, et pour qui c'est utile.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎯</div>
          <h3>Le prompt prêt à l'emploi</h3>
          <p>Un prompt professionnel à copier-coller directement dans ChatGPT, Claude ou Gemini. Avec explication et exemples de résultats.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Le tuto express</h3>
          <p>Un cas d'usage concret : « Comment j'ai automatisé X avec l'IA en 10 minutes ». Actionnable immédiatement.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <h3>L'actu IA qui compte</h3>
          <p>Les 3-5 infos IA les plus importantes de la semaine, résumées en 2 lignes chacune. Pas de bruit, que du signal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POUR QUI -->
  <section class="audience">
    <div class="audience-inner">
      <h2>C'est pour toi si...</h2>
      <div class="audience-grid">
        <div class="audience-item">
          <span class="check">✓</span>
          <p>Tu veux utiliser l'IA concrètement mais tu ne sais pas par où commencer</p>
        </div>
        <div class="audience-item">
          <span class="check">✓</span>
          <p>Tu perds du temps à chercher les bons prompts et les bons outils</p>
        </div>
        <div class="audience-item">
          <span class="check">✓</span>
          <p>Tu veux automatiser des tâches répétitives dans ton travail</p>
        </div>
        <div class="audience-item">
          <span class="check">✓</span>
          <p>Tu veux rester à jour sur l'IA sans y passer des heures chaque jour</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUITS -->
  <section class="products" id="produits">
    <div class="products-inner">
      <h2>Nos ressources</h2>
      <p class="products-sub">Des outils concrets pour passer à l'action</p>
      <div class="products-grid">
        <div class="product-card free">
          <div class="product-badge free-badge">GRATUIT</div>
          <h3>Le Guide du Prompting</h3>
          <p>7 règles d'or + 20 prompts professionnels prêts à l'emploi. Le guide essentiel pour bien démarrer avec l'IA.</p>
          <span class="product-price">0 €</span>
          <a href="#" class="btn-product">Télécharger gratuitement</a>
        </div>
        <div class="product-card">
          <div class="product-badge">BEST-SELLER</div>
          <h3>Pack 50 Prompts Pro</h3>
          <p>50 prompts professionnels testés et classés par catégorie : marketing, ventes, productivité, analyse, rédaction.</p>
          <span class="product-price">9 €</span>
          <a href="#" class="btn-product">Découvrir</a>
        </div>
        <div class="product-card">
          <div class="product-badge soon-badge">BIENTÔT</div>
          <h3>E-book « Automatise ta Semaine »</h3>
          <p>Le guide complet pour automatiser tes tâches quotidiennes avec l'IA. 50+ pages de cas concrets et tutoriels.</p>
          <span class="product-price">12 €</span>
          <a href="#inscription" class="btn-product btn-soon">Inscris-toi pour être prévenu</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="cta-final">
    <div class="cta-inner">
      <h2>Prêt à passer au niveau supérieur avec l'IA ?</h2>
      <p>Rejoins Prompt Hebdo et reçois chaque semaine des prompts, outils et tutoriels actionnables.</p>
      <a href="#inscription" class="btn-primary btn-large">S'inscrire gratuitement →</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero {
    background: linear-gradient(135deg, #f0f5ff 0%, #e8f0fe 50%, #f3e8ff 100%);
    padding: 5rem 1.5rem 4rem;
    text-align: center;
  }
  .hero-inner { max-width: 750px; margin: 0 auto; }
  .hero-badge {
    display: inline-block; background: #fff; border: 1px solid var(--gray-200);
    padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.85rem;
    color: var(--gray-600); margin-bottom: 1.5rem; font-weight: 500;
  }
  h1 {
    font-size: 2.8rem; font-weight: 800; line-height: 1.15;
    color: var(--gray-900); margin-bottom: 1.2rem;
  }
  .highlight {
    background: linear-gradient(135deg, var(--blue), var(--purple));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-sub {
    font-size: 1.15rem; color: var(--gray-600); max-width: 600px;
    margin: 0 auto 2rem; line-height: 1.7;
  }
  .signup-box {
    background: #fff; border-radius: var(--radius); padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08); max-width: 500px; margin: 0 auto;
  }
  .signup-label { font-weight: 600; margin-bottom: 0.8rem; color: var(--gray-800); }
  .signup-placeholder { display: flex; gap: 0.5rem; }
  .signup-input {
    flex: 1; padding: 0.7rem 1rem; border: 1px solid var(--gray-200);
    border-radius: 8px; font-size: 1rem; font-family: inherit;
  }
  .signup-input:focus { outline: none; border-color: var(--blue); box-shadow: 0 0 0 3px rgba(26,86,219,0.1); }
  .btn-primary {
    background: var(--blue); color: #fff; border: none; padding: 0.7rem 1.5rem;
    border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer;
    font-family: inherit; transition: background 0.2s; white-space: nowrap;
    display: inline-block;
  }
  .btn-primary:hover { background: #1e40af; text-decoration: none; }
  .btn-large { padding: 0.9rem 2rem; font-size: 1.1rem; }
  .signup-hint { font-size: 0.8rem; color: var(--gray-400); margin-top: 0.6rem; }
  .hero-proof {
    display: flex; justify-content: center; gap: 1.5rem;
    margin-top: 1.5rem; font-size: 0.9rem; color: var(--gray-600);
  }

  /* FEATURES */
  .features { padding: 4rem 1.5rem; }
  .features-inner { max-width: 1000px; margin: 0 auto; }
  .features-inner h2 { text-align: center; font-size: 2rem; margin-bottom: 2.5rem; color: var(--gray-900); }
  .features-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .feature-card {
    padding: 1.8rem; border-radius: var(--radius);
    border: 1px solid var(--gray-200); transition: box-shadow 0.2s;
  }
  .feature-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .feature-icon { font-size: 2rem; margin-bottom: 0.8rem; }
  .feature-card h3 { font-size: 1.15rem; margin-bottom: 0.5rem; color: var(--gray-900); }
  .feature-card p { color: var(--gray-600); font-size: 0.95rem; line-height: 1.6; }

  /* AUDIENCE */
  .audience { padding: 4rem 1.5rem; background: var(--gray-50); }
  .audience-inner { max-width: 700px; margin: 0 auto; }
  .audience-inner h2 { text-align: center; font-size: 2rem; margin-bottom: 2rem; color: var(--gray-900); }
  .audience-grid { display: flex; flex-direction: column; gap: 1rem; }
  .audience-item {
    display: flex; align-items: flex-start; gap: 0.8rem;
    padding: 1rem 1.2rem; background: #fff; border-radius: var(--radius);
    border: 1px solid var(--gray-200);
  }
  .check { color: var(--green); font-weight: 700; font-size: 1.2rem; flex-shrink: 0; }
  .audience-item p { font-size: 1rem; color: var(--gray-700); }

  /* PRODUCTS */
  .products { padding: 4rem 1.5rem; }
  .products-inner { max-width: 1000px; margin: 0 auto; text-align: center; }
  .products-inner h2 { font-size: 2rem; margin-bottom: 0.5rem; color: var(--gray-900); }
  .products-sub { color: var(--gray-600); margin-bottom: 2.5rem; }
  .products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; text-align: left; }
  .product-card {
    padding: 1.8rem; border-radius: var(--radius);
    border: 1px solid var(--gray-200); position: relative;
    display: flex; flex-direction: column;
  }
  .product-card.free { border-color: var(--green); }
  .product-badge {
    display: inline-block; background: var(--blue); color: #fff;
    padding: 0.2rem 0.7rem; border-radius: 50px; font-size: 0.7rem;
    font-weight: 700; letter-spacing: 0.5px; margin-bottom: 1rem; width: fit-content;
  }
  .free-badge { background: var(--green); }
  .soon-badge { background: var(--gray-400); }
  .product-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; color: var(--gray-900); }
  .product-card p { font-size: 0.9rem; color: var(--gray-600); line-height: 1.6; flex: 1; }
  .product-price {
    display: block; font-size: 1.5rem; font-weight: 800;
    color: var(--gray-900); margin: 1rem 0;
  }
  .btn-product {
    display: block; text-align: center; padding: 0.6rem;
    background: var(--blue); color: #fff; border-radius: 8px;
    font-weight: 600; font-size: 0.9rem; transition: background 0.2s;
  }
  .btn-product:hover { background: #1e40af; text-decoration: none; }
  .btn-soon { background: var(--gray-600); }
  .btn-soon:hover { background: var(--gray-800); }

  /* CTA */
  .cta-final {
    padding: 4rem 1.5rem; text-align: center;
    background: linear-gradient(135deg, var(--blue-dark), #2d1b69);
    color: #fff;
  }
  .cta-inner { max-width: 600px; margin: 0 auto; }
  .cta-final h2 { font-size: 1.8rem; margin-bottom: 1rem; color: #fff; }
  .cta-final p { color: rgba(255,255,255,0.8); margin-bottom: 1.5rem; font-size: 1.05rem; }
  .cta-final .btn-primary { background: #fff; color: var(--blue); }
  .cta-final .btn-primary:hover { background: var(--gray-100); }

  @media (max-width: 768px) {
    h1 { font-size: 2rem; }
    .features-grid { grid-template-columns: 1fr; }
    .products-grid { grid-template-columns: 1fr; }
    .hero-proof { flex-direction: column; gap: 0.5rem; }
    .signup-placeholder { flex-direction: column; }
  }
</style>
