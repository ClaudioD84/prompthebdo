---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Les articles seront ajoutés ici au fur et à mesure
const articles = [
  {
    title: "5 outils IA gratuits qui vont changer ta façon de travailler",
    description: "Claude, Perplexity, Gamma, Notion AI, ElevenLabs — on a testé les meilleurs outils IA gratuits de 2026.",
    date: "2026-04-08",
    slug: "5-outils-ia-gratuits",
    tag: "Outils",
  },
  {
    title: "Le guide du prompting : 7 règles pour des résultats 10x meilleurs",
    description: "Rôle, contexte, contraintes, itération... Les 7 techniques qui transforment tes prompts de basiques à professionnels.",
    date: "2026-04-11",
    slug: "guide-prompting-7-regles",
    tag: "Prompts",
  },
  {
    title: "J'ai automatisé ma veille IA en 10 minutes — voici comment",
    description: "Feedly + Claude + Zapier : le système en 3 étapes pour ne plus jamais rater une info IA importante.",
    date: "2026-04-15",
    slug: "automatiser-veille-ia",
    tag: "Automatisation",
  },
];

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout title="Blog — Prompt Hebdo" description="Articles, tutoriels et guides pratiques sur l'IA et l'automatisation.">
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <h1>Le Blog</h1>
      <p>Articles, tutoriels et guides pour maîtriser l'IA au quotidien.</p>
    </div>
  </section>

  <section class="blog-list">
    <div class="blog-list-inner">
      {articles.map((article) => (
        <article class="blog-card">
          <div class="blog-card-tag">{article.tag}</div>
          <h2><a href={`/blog/${article.slug}`}>{article.title}</a></h2>
          <p>{article.description}</p>
          <time>{formatDate(article.date)}</time>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    background: linear-gradient(135deg, #f0f5ff, #f3e8ff);
    padding: 4rem 1.5rem 3rem; text-align: center;
  }
  .blog-hero-inner { max-width: 600px; margin: 0 auto; }
  .blog-hero h1 { font-size: 2.5rem; color: var(--gray-900); margin-bottom: 0.5rem; }
  .blog-hero p { color: var(--gray-600); font-size: 1.1rem; }

  .blog-list { padding: 3rem 1.5rem; }
  .blog-list-inner { max-width: 750px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.5rem; }

  .blog-card {
    padding: 1.5rem; border: 1px solid var(--gray-200);
    border-radius: var(--radius); transition: box-shadow 0.2s;
  }
  .blog-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
  .blog-card-tag {
    display: inline-block; background: var(--blue-light); color: var(--blue);
    padding: 0.2rem 0.6rem; border-radius: 50px; font-size: 0.75rem;
    font-weight: 600; margin-bottom: 0.8rem;
  }
  .blog-card h2 { font-size: 1.2rem; margin-bottom: 0.5rem; }
  .blog-card h2 a { color: var(--gray-900); }
  .blog-card h2 a:hover { color: var(--blue); }
  .blog-card p { color: var(--gray-600); font-size: 0.95rem; margin-bottom: 0.5rem; }
  .blog-card time { font-size: 0.8rem; color: var(--gray-400); }
</style>
