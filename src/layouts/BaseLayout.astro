---
interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = "Chaque semaine, des prompts IA prêts à l'emploi, des outils testés et des tutoriels concrets pour automatiser ton quotidien.",
  image = '/og-image.png',
  type = 'website',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://www.prompthebdo.fr');
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content={type} />
  <meta property="og:site_name" content="Prompt Hebdo" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:image" content={ogImageURL.href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL.href} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --blue: #1a56db;
      --blue-dark: #1e3a5f;
      --blue-light: #e8f0fe;
      --purple: #7c3aed;
      --purple-light: #f3e8ff;
      --green: #059669;
      --orange: #ea580c;
      --gray-50: #f9fafb;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-400: #9ca3af;
      --gray-600: #4b5563;
      --gray-800: #1f2937;
      --gray-900: #111827;
      --radius: 12px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--gray-800);
      line-height: 1.6;
      background: #fff;
    }
    a { color: var(--blue); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; height: auto; }
  </style>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">⚡</span> Prompt Hebdo
      </a>
      <div class="nav-links">
        <a href="/blog">Blog</a>
        <a href="/#produits">Produits</a>
        <a href="/#inscription" class="btn-nav">S'inscrire gratuitement</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <span class="logo-icon">⚡</span> Prompt Hebdo
        <p class="footer-tagline">L'IA pratique, chaque semaine dans ta boite mail.</p>
      </div>
      <div class="footer-links">
        <a href="/blog">Blog</a>
        <a href="/#produits">Produits</a>
        <a href="/#inscription">Newsletter</a>
      </div>
      <p class="footer-copy">&copy; 2026 Prompt Hebdo. Tous droits réservés.</p>
    </div>
  </footer>

  <style>
    .nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(255,255,255,0.95); backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--gray-200);
    }
    .nav-inner {
      max-width: 1100px; margin: 0 auto; padding: 0.8rem 1.5rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .logo {
      font-size: 1.3rem; font-weight: 800; color: var(--gray-900);
      display: flex; align-items: center; gap: 0.3rem;
    }
    .logo:hover { text-decoration: none; }
    .logo-icon { font-size: 1.5rem; }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; }
    .nav-links a { color: var(--gray-600); font-size: 0.95rem; font-weight: 500; }
    .btn-nav {
      background: var(--blue) !important; color: #fff !important;
      padding: 0.5rem 1.2rem; border-radius: 8px; font-weight: 600 !important;
      transition: background 0.2s;
    }
    .btn-nav:hover { background: #1e40af !important; text-decoration: none !important; }
    .footer {
      background: var(--gray-900); color: var(--gray-400);
      padding: 3rem 1.5rem; margin-top: 4rem;
    }
    .footer-inner {
      max-width: 1100px; margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; gap: 1rem; text-align: center;
    }
    .footer-brand { font-size: 1.2rem; font-weight: 700; color: #fff; }
    .footer-tagline { font-size: 0.9rem; color: var(--gray-400); margin-top: 0.3rem; font-weight: 400; }
    .footer-links { display: flex; gap: 1.5rem; }
    .footer-links a { color: var(--gray-400); font-size: 0.9rem; }
    .footer-links a:hover { color: #fff; }
    .footer-copy { font-size: 0.8rem; }
    @media (max-width: 768px) {
      .nav-links { gap: 0.8rem; }
      .nav-links a:not(.btn-nav) { display: none; }
    }
  </style>
</body>
</html>
